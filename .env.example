# Copy to `.env` (gitignored) and fill in real values.
# Loaded automatically by pytest-dotenv when present; otherwise export manually.

# ---- LLM / embedding credentials ----
# Same key goes to both env vars — the anthropic SDK reads ANTHROPIC_API_KEY
# and the openai SDK reads OPENAI_API_KEY. MiniMax uses one key for both.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- live MiniMax smoke test (tests/test_mvp_e2e.py) ----
# All five must be set for the smoke test to run; missing any one skips it.
MINIMAX_API_KEY=
MINIMAX_LLM_MODEL=
MINIMAX_LLM_BASE_URL=
MINIMAX_EMBEDDING_MODEL=
MINIMAX_EMBEDDING_BASE_URL=

# ---- optional: Postgres storage-contract tests ----
# Leave unset to skip; set to a pgvector-enabled DSN to include them.
# DIKW_TEST_POSTGRES_DSN=postgresql://dikw:dikw@localhost:5432/dikw_test
